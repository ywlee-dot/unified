# --- 앱 설정 ---
APP_NAME=unified-workspace
DEBUG=true

# --- 데이터베이스 ---
POSTGRES_DB=workspace
POSTGRES_USER=workspace_user
POSTGRES_PASSWORD=workspace_pass
DATABASE_URL=postgresql+asyncpg://workspace_user:workspace_pass@db:5432/workspace
DB_POOL_SIZE=10          # DB 커넥션 풀 크기
DB_MAX_OVERFLOW=20       # 최대 초과 커넥션 수
DB_POOL_RECYCLE=3600     # 커넥션 재활용 주기 (초)

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- n8n ---
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_BASE_1=https://ywlee.app.n8n.cloud/webhook       # n8n 계정1 webhook base
N8N_WEBHOOK_BASE_2=                                           # n8n 계정2 webhook base
N8N_WEBHOOK_BASE_3=                                           # n8n 계정3 webhook base
N8N_API_KEY=                              # n8n API 키 (n8n에서 발급)
N8N_CALLBACK_SECRET=n8n-callback-secret-change-me  # n8n 콜백 인증 시크릿
N8N_BASIC_AUTH_USER=admin                 # n8n 기본 인증 사용자
N8N_BASIC_AUTH_PASSWORD=admin             # n8n 기본 인증 비밀번호

# --- CORS ---
CORS_ORIGINS=http://localhost:3000        # 쉼표 구분, 예: http://localhost:3000,https://example.com

# --- 인증 ---
SECRET_KEY=dev-secret-key-change-in-production  # JWT 서명 키 (프로덕션에서 반드시 변경)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- LLM (데이터셋 설명 생성) ---
GEMINI_API_KEY=                           # Google Gemini API 키
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=                           # OpenAI API 키 (선택)
OPENAI_BASE_URL=                          # OpenAI 호환 API 엔드포인트 (선택)
OPENAI_MODEL=                             # OpenAI 모델명 (선택)
MOCK_MODE=0                               # 1로 설정 시 LLM 호출 없이 목업 데이터 사용

# --- Pinecone (평가편람 RAG) ---
PINECONE_API_KEY=                         # Pinecone API 키
PINECONE_INDEX_NAME=evaluation-guidelines # Pinecone 인덱스명

# --- 로깅 ---
LOG_LEVEL=INFO                            # DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- 프론트엔드 ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api  # 클라이언트(브라우저)용 API URL
INTERNAL_API_URL=http://backend:8000/api       # 서버(SSR)용 내부 API URL
