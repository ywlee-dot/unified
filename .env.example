# --- App Settings ---
APP_NAME=unified-workspace
DEBUG=true

# --- Database ---
POSTGRES_DB=workspace
POSTGRES_USER=workspace_user
POSTGRES_PASSWORD=workspace_pass
DATABASE_URL=postgresql+asyncpg://workspace_user:workspace_pass@db:5432/workspace

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- n8n ---
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_BASE=http://n8n:5678/webhook
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# --- Auth ---
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- LLM (Dataset Summary) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
MOCK_MODE=0

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api
INTERNAL_API_URL=http://backend:8000/api
